# SMTP 配置
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_TEST_USER=

# 服务端口配置
APP_PORT=9023            # 前端访问端口
REDIS_PORT=6379          # Redis 端口
REDIS_INSIGHT_PORT=8001  # RedisInsight 管理界面端口

# 爬虫配置
SITEMAP_URL=
CRAWLER_TIMEOUT=30
CRAWLER_MAX_URLS=
CRAWLER_DELAY=0.5
CRAWLER_OUTPUT_DIR=./crawl_results
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# URL过滤规则（可选，使用正则表达式）
# CRAWLER_URL_INCLUDE_PATTERNS=["/docs/", "/api/"]  # 只爬取包含这些路径的URL
# CRAWLER_URL_EXCLUDE_PATTERNS=["/admin/", "/private/"]  # 排除包含这些路径的URL

# Firecrawl MCP 配置(用于动态网页渲染和解析)
FIRECRAWL_ENABLED=false  # 是否启用 Firecrawl(true/false)
# 注意: Firecrawl 运行在独立的 Docker Compose 中,需要使用宿主机地址访问
# 如果使用 Docker Desktop (Windows/Mac),使用 host.docker.internal
# 如果使用 Linux,使用 localhost 或 127.0.0.1
# Firecrawl 默认端口为 3002,如需修改请编辑 submodules/firecrawl/.env
FIRECRAWL_API_URL=http://host.docker.internal:3002  # Firecrawl 服务地址
# FIRECRAWL_API_KEY=fc-xxxx  # Firecrawl API Key(使用官方 API 时需要)
FIRECRAWL_TIMEOUT=600  # Firecrawl 请求超时时间(秒)
FIRECRAWL_USE_OFFICIAL=false  # 是否使用官方 API(true/false)
FIRECRAWL_ONLY_MAIN_CONTENT=true  # 是否只提取主要内容(true/false)

# 定时任务配置（每天执行时间）
SCHEDULER_HOUR=22
SCHEDULER_MINUTE=0

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Rerank 模型配置（用于智能推荐重排序）
RERANK_ENABLED=false  # 是否启用 Rerank 模型（true/false）
# 注意：如果不配置以下两项，将自动复用 OPENAI_API_BASE 和 OPENAI_API_KEY
# 推荐使用硅基流动（SiliconFlow）的免费 Rerank 模型：https://cloud.siliconflow.cn/
RERANK_API_URL=https://cloud.siliconflow.cn/v1
RERANK_API_KEY=
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Redis 配置
# 本地开发: REDIS_URL=redis://localhost:6379
# Docker部署: REDIS_URL=redis://redis:6379 (使用Docker服务名)
REDIS_URL=redis://redis:6379

# 单页最大内容长度（字符），超过此长度会进行chunk分割处理
MAX_CONTENT_LENGTH_PER_PAGE=2000

# LLM Token限制配置（可选，不配置则使用模型默认值）
MODEL_MAX_INPUT_TOKENS=128000
# max_output_tokens: LLM输出的最大token数，增大以避免JSON截断（deepseek支持16384）
MODEL_MAX_OUTPUT_TOKENS=16384
