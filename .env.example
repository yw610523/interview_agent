# ============================================================
# 环境变量配置示例
# ============================================================
# 将此文件复制为 .env 或在 Jenkins 中设置这些环境变量
# 敏感信息（API Key、密码等）必须通过环境变量注入
# ============================================================

# -------------------- Redis 配置 --------------------
REDIS_HOST=hp.yys2024.cn
REDIS_PORT=6679
REDIS_PASSWORD=your_redis_password

# -------------------- SMTP 邮件配置 --------------------
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code
SMTP_TEST_USER=test@example.com

# -------------------- LLM 配置 --------------------
OPENAI_API_KEY=sk-your-api-key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# -------------------- Firecrawl 配置 --------------------
FIRECRAWL_ENABLED=false
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=your_firecrawl_key
FIRECRAWL_TIMEOUT=600

# -------------------- Rerank 配置 --------------------
RERANK_ENABLED=true
RERANK_API_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=sk-your-rerank-key
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# -------------------- 爬虫配置 --------------------
CRAWLER_SITEMAP_URL=javaguide.com
CRAWLER_TIMEOUT=30
CRAWLER_MAX_URLS=
CRAWLER_DELAY=0.5
CRAWLER_SCHEDULER_HOUR=22
CRAWLER_SCHEDULER_MINUTE=0

# -------------------- 服务端口配置 --------------------
APP_PORT=9023
REDIS_INSIGHT_PORT=8001

# -------------------- 内容处理配置 --------------------
MAX_CONTENT_LENGTH_PER_PAGE=2000
